# Copy this file to .env and replace all placeholder values before running Docker.
# Local Docker Compose only (not required by Railway's single-service image).
POSTGRES_PASSWORD=replace-with-a-strong-database-password
# URL-encode special characters in the password used below (for example, @ becomes %40).
DATABASE_URL=postgresql://postgres:replace-with-a-url-encoded-database-password@db:5432/interviewguard
SECRET_KEY=replace-with-a-long-random-secret-key
# Railway production: set DATABASE_URL to its PostgreSQL connection URL and set
# SECRET_KEY to a unique random value. SQLite is used only when DATABASE_URL is absent.
SMTP_USER=
SMTP_PASSWORD=
# Public Railway URL, for example: https://your-app.up.railway.app
PUBLIC_APP_URL=
